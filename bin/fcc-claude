#!/usr/bin/env bash
# Wrapper script for fcc-claude from the local cloned repo.
# Used by claude-web-ui via CLAUDE_CLI_PATH=./bin/fcc-claude
set -euo pipefail

FCC_REPO="/root/Workspace/free-claude-code"

if [ ! -d "$FCC_REPO" ]; then
    echo "FCC repo not found at $FCC_REPO" >&2
    echo "Clone it first: git clone https://github.com/Alishahryar1/free-claude-code.git" >&2
    exit 1
fi

exec uv run --directory "$FCC_REPO" fcc-claude "$@"
