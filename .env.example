# Claude Web UI Environment Configuration
# Only includes variables that are actually used in the code
#
# TIP: Run 'claude-web-ui status' to see where this file should be located
#      and to view your current configuration.
#
# Available CLI commands:
#   claude-web-ui         - Start the server (default)
#   claude-web-ui start   - Start the server
#   claude-web-ui status  - Show configuration and data locations
#   claude-web-ui help    - Show help information
#   claude-web-ui version - Show version information

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Backend server port (Express API + WebSocket server)
#API server
SERVER_PORT=3001
#Frontend port
VITE_PORT=5173

# Host/IP to bind servers to (default: 0.0.0.0 for all interfaces)
# Use 127.0.0.1 to restrict to localhost only
HOST=0.0.0.0

# Override the Claude Code executable path. The SDK checks the musl variant
# first on Linux, which fails on glibc-based distros (Ubuntu, Debian, etc.).
# Set this to the compatible binary path to skip the SDK's resolution:
# Path to the Claude Code binary. Default: searches PATH for `claude`.
# CLAUDE_CLI_PATH=/path/to/your/project/node_modules/@anthropic-ai/claude-agent-sdk-linux-x64/claude
# If using the local FCC clone (recommended): ./bin/fcc-claude

# Comma-separated list of allowed CORS origins.
# Default: http://localhost:3001,http://localhost:5173,http://127.0.0.1:3001,http://127.0.0.1:5173
# ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

# Enable "plain shell" mode that runs arbitrary commands via the shell terminal.
# WARNING: Only enable if you trust every user who can authenticate to the Web UI.
# Default: false
# IS_PLAIN_SHELL_ENABLED=false

# **REQUIRED** when VITE_IS_PLATFORM=true.
# Shared secret for platform mode. The reverse proxy must include this
# value in the x-platform-shared-secret header on every request.
# The server will FATAL-EXIT at startup if VITE_IS_PLATFORM=true
# and this variable is not set.
# PLATFORM_SHARED_SECRET=your-secret-here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Path to the authentication database file
# This is where user credentials, API keys, and tokens are stored.
#
# To use a custom location:
# DATABASE_PATH=/path/to/your/custom/auth.db
#
# Claude Code context window size (maximum tokens per session)
VITE_CONTEXT_WINDOW=160000
CONTEXT_WINDOW=160000

# =============================================================================
# FCC / PROXY CONFIGURATION
# =============================================================================

# Point to a local Free Claude Code (FCC) proxy instance.
# When set to a localhost URL, the server routes API calls through FCC
# instead of directly to api.anthropic.com.
#
# ANTHROPIC_BASE_URL=http://127.0.0.1:8082

# Auth token for the FCC proxy (defaults to "freecc" if not set).
#
# ANTHROPIC_AUTH_TOKEN=your-fcc-token

# =============================================================================
# CONFIGURATION FILE LOCATIONS (loaded in priority order)
# =============================================================================
#
#   1. Shell environment variables (export ANTHROPIC_BASE_URL=...)
#   2. CLI flags (--anthropic-base-url, --anthropic-auth-token)
#   3. ./.env — this file, placed in your project directory
#   4. ~/.config/claude-web-ui/.env — global user config, set once
#   5. ~/.config/free-claude-code/.env — auto-discovered from FCC install
#
# Use 'claude-web-ui status' to see your current configuration.
# Use 'claude-web-ui help' for all available CLI options.

